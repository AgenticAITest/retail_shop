# Database configuration
DATABASE_URL=postgresql://retail_user:retail_pass@localhost:5432/retail_multitenant

# Tenant Connection Configuration
SHARED_SCHEMA=public
MAX_TENANT_SCHEMAS=100
TENANT_SCHEMA_PREFIX=tenant_
MAX_CONNECTIONS=10
IDLE_TIMEOUT=30000
ENABLE_QUERY_LOGGING=true
CONNECTION_LOG_LEVEL=info

# JWT secrets
ACCESS_TOKEN_SECRET=my_access_token_secret_key
REFRESH_TOKEN_SECRET=my_refresh_token_secret_key
RESET_PASSWORD_TOKEN_SECRET=my_reset_password_token_secret_key

# Base URL
BASE_URL=http://localhost:5000
NODE_ENV=development

# Redis configuration
REDIS_URL=redis://localhost:6379

# SMTP configuration
SMTP_HOST="127.0.0.1"
SMTP_PORT=25
SMTP_USER="user-smtp"
SMTP_PASS="pass-smtp"
SMTP_FROM="Retail Shop <noreply@retailshop.com>"

# Sentry (optional)
SENTRY_DSN=
