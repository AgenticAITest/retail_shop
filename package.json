{
  "name": "react-admin",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "nodemon -w src/server -x tsx src/server/main.ts",
    "start": "NODE_ENV=production tsx src/server/main.ts",
    "build": "vite build",
    "create-module": "node scripts/create-module.js",
    "create-module-cli": "node scripts/create-module-cli.js",
    "add-page": "node scripts/add-page-to-module.js",
    "register-module": "node scripts/register-module.js",
    "db:register-module": "node scripts/register-module-db.js",
    "generate-sql": "node scripts/generate-module-sql.js",
    "db:install-module": "echo 'Run: psql -d your_database -f modules/[module-id]/scripts/install.sql'",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/server/lib/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "test:e2e": "playwright test --project=sysadmin",
    "test:e2e:ui": "playwright test --ui --project=sysadmin",
    "test:e2e:headed": "playwright test --headed --project=sysadmin",
    "test:e2e:debug": "playwright test --debug --project=sysadmin",
    "test:e2e:report": "playwright show-report",
    "test:e2e:rbac": "playwright test --project=rbac",
    "test:e2e:admin": "playwright test --project=admin",
    "test:e2e:manager": "playwright test --project=manager",
    "test:e2e:cashier": "playwright test --project=cashier",
    "test:e2e:all": "playwright test",
    "db:create-module-tables": "node scripts/create-module-tables.mjs"
  },
